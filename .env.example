# ─────────────────────────────────────────────────────────────────────────────
# StoreLink environment variables
# Copy this file to ".env.local" and fill in the values you need.
# With NONE of these set, the app runs in DEMO MODE (in-memory data, resets on
# restart) — perfect for local testing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database & storage (Supabase) ────────────────────────────────────────────
# Set BOTH to switch from demo mode to a real, persistent database.
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER secret — never expose

# ── Security (required in production) ────────────────────────────────────────
# Long random string. Generate: openssl rand -base64 48
# In dev it falls back to an insecure default; in production the app requires it.
SESSION_SECRET=replace-with-a-long-random-string
# Optional but RECOMMENDED: a dedicated key for encrypting CNIC/payout numbers.
# Falls back to SESSION_SECRET if unset — but then rotating SESSION_SECRET would
# make already-stored CNIC/payout values unreadable. Set this separately so you
# can rotate the session secret without orphaning encrypted PII.
# Generate: openssl rand -base64 48
FIELD_ENCRYPTION_KEY=

# ── Public site URL (SEO, sitemap, email links, OG images) ───────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # in production: https://storelink.pk

# ── Email (Resend) ───────────────────────────────────────────────────────────
# In DEV without a key, emails are printed to the console (so you can test).
# In PRODUCTION the app REQUIRES this key — without it, mail send fails loudly
# (it will NOT log message bodies, which can contain PII + password-reset links).
RESEND_API_KEY=
EMAIL_FROM=StoreLink <noreply@storelink.pk>   # must be a domain verified in Resend

# ── Support contact (the WhatsApp number sellers reach you on) ───────────────
# International digits, NO "+". A Pakistani number looks like 923001234567.
NEXT_PUBLIC_SUPPORT_WHATSAPP=923390331975
NEXT_PUBLIC_SUPPORT_EMAIL=support@storelink.pk

# ── Analytics (optional — use one) ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=                 # e.g. G-XXXXXXXXX  (Google Analytics 4)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=      # e.g. storelink.pk (Plausible)

# ── Subscription billing gate (OFF by default — keep blank until you're ready) ─
# BILLING_GATE=1            -> turns on the pay-to-use gate (paused/pending shops
#                             see a "contact us on WhatsApp" screen + closed storefront)
# BILLING_PAY_FIRST=1       -> new signups start as "pending" (pay before using).
#                             Leave unset for trial-first (recommended).
# BILLING_WEBHOOK_SECRET=.. -> only when you wire a real payment gateway to
#                             /api/billing/webhook
BILLING_GATE=
BILLING_PAY_FIRST=
BILLING_WEBHOOK_SECRET=
